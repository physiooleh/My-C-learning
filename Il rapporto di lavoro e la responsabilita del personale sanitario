#include <iostream>
using namespace std;

int Mountain1 = 3500;
int Mountain2 = 3400;
int Mountain3 = 3300;
int Mountain4 = 3200;
int Mountain5 = 3100;
int Mountain6 = 3000;
int Mountain7 = 2900;
int Mountain8 = 2800;
int Mountain9 = 2700;

int main() {

    int sum = Mountain1 + Mountain2 + Mountain3 + Mountain4 +
              Mountain5 + Mountain6 + Mountain7 + Mountain8 + Mountain9;

    double average = sum / 9.0;   // 9.0 щоб ділення було не цілочисельне

    cout << "Average height: " << average << endl;

    return 0;
}
## 💡 Дуже важливий момент

Якби ти написав:

```cpp
double average = sum / 9;
```

то вийшло б **цілочисельне ділення**, і дробова частина загубилась би.

Тому:

* або `9.0`
* або `static_cast<double>(sum) / 9`

---

## 🚀 А тепер невеликий професійний апгрейд

Те, що ти зробив — правильно для початку.

Але в реальному коді так не пишуть 9 окремих змінних. Краще використовувати масив:

```cpp
int mountains[9] = {3500, 3400, 3300, 3200, 3100, 3000, 2900, 2800, 2700};

int main() {

    int sum = 0;

    for(int i = 0; i < 9; i++) {
        sum += mountains[i];
    }

    double average = sum / 9.0;

    cout << "Average height: " << average << endl;

    return 0;
}
```

